<workflow-app name="masspers-prod-erib-operation-upd-${instanceName}-datamarts" xmlns="uri:oozie:workflow:0.4">
    <global>
        <configuration>
            <property>
                <name>mapred.job.queue.name</name>
                <value>${yarnQueue}</value>
            </property>
        </configuration>
    </global>

    <start to="validate-ctl-version"/>

    <action name="validate-ctl-version">
        <sub-workflow>
            <app-path>/oozie-app/wf/custom/rb/production/utils/common/validate-ctl-version</app-path>
            <propagate-configuration/>
        </sub-workflow>
        <ok to="create-recount-sbol"/>
        <error to="kill"/>
    </action>

    <action name="create-recount-sbol">
        <sub-workflow>
            <app-path>/oozie-app/wf/custom/rb/production/erib/generated/create-recount-sbol-${instanceName}-wf</app-path>
            <propagate-configuration/>
        </sub-workflow>
        <ok to="create-sbol-receivers-bd"/>
        <error to="kill"/>
    </action>

    <action name="create-sbol-receivers-bd">
        <sub-workflow>
            <app-path>/oozie-app/wf/custom/rb/production/erib/generated/create-sbol-receivers-bd-${instanceName}-wf</app-path>
            <propagate-configuration/>
        </sub-workflow>
        <ok to="create-sbol-oper-upd"/>
        <error to="kill"/>
    </action>

    <action name="create-sbol-oper-upd">
        <sub-workflow>
            <app-path>/oozie-app/wf/custom/rb/production/erib/generated/create-sbol-oper-upd-${instanceName}-wf</app-path>
            <propagate-configuration/>
        </sub-workflow>
        <ok to="end"/>
        <error to="kill"/>
    </action>

    <kill name="kill">
        <message>Action failed, error message[${wf:errorMessage(wf:lastErrorNode())}]</message>
    </kill>
    <end name="end"/>

</workflow-app>
