<workflow-app name="masspers-evk-campaign-hst-snp-monthly-datamart" xmlns="uri:oozie:workflow:0.4">
    <global>
        <configuration>
            <property>
                <name>mapred.job.queue.name</name>
                <value>${yarnQueue}</value>
            </property>
        </configuration>
    </global>

    <start to="validate-ctl-version"/>

    <action name="validate-ctl-version">
        <sub-workflow>
            <app-path>/oozie-app/wf/custom/rb/production/utils/common/validate-ctl-version</app-path>
            <propagate-configuration/>
        </sub-workflow>
        <ok to="create-evk-campaign-hst-snp-monthly"/>
        <error to="kill"/>
    </action>

    <action name="create-evk-campaign-hst-snp-monthly">
        <sub-workflow>
            <app-path>/oozie-app/wf/custom/rb/production/greenplum/generated/create-dm-union-campaign-history-snp-wf</app-path>
            <propagate-configuration/>
        </sub-workflow>
        <ok to="end"/>
        <error to="kill"/>
    </action>

    <kill name="kill">
        <message>Action failed, error message[${wf:errorMessage(wf:lastErrorNode())}]</message>
    </kill>

    <end name="end"/>
</workflow-app>
